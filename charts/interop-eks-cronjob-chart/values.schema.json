{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "cronjob": {
      "type": "object",
      "properties": {
        "image": {
          "description": "Container Image",
          "properties": {
            "repositoryPrefix": {
              "type": "string"
            },
            "imagePullPolicy": {
              "type": "string"
            }
          },
          "type": "object",
          "required": [
            "repositoryPrefix"
          ]
        },
        "resources": {
          "description": "Container Resources consumption",
          "properties": {
            "requests": {
              "properties": {
                "cpu": {
                  "type": "string"
                },
                "memory": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "limits": {
              "properties": {
                "cpu": {
                  "type": "string"
                },
                "memory": {
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "schedule": {
          "description": "Cronjob scheduling expression",
          "type": "string"
        },
        "flywayInitContainer": {
          "description": "Optional Flyway init container configuration",
          "properties": {
            "create": {
              "description": "Enable the Flyway init container",
              "type": "boolean"
            },
            "image": {
              "description": "Flyway init container image configuration",
              "properties": {
                "repositoryPrefix": {
                  "description": "Image repository prefix; defaults to cronjob.image.repositoryPrefix if not set",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "repositoryName": {
                  "description": "Image repository name; required when create is true",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "tag": {
                  "description": "Image tag; defaults to cronjob.image.tag if not set",
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "digest": {
                  "description": "Image digest; if set, overrides tag",
                  "type": [
                    "string",
                    "null"
                  ]
                }
              },
              "type": "object"
            },
            "executeFlywayMigrate": {
              "description": "Execute Flyway migrate command to apply migrations to the database",
              "type": "boolean"
            },
            "executeFlywayRepair": {
              "description": "Execute Flyway repair command to recompute applied migrations checksum metadata",
              "type": "boolean"
            },
            "downloadRedshiftDriver": {
              "description": "Enable Flyway to download the Redshift JDBC driver",
              "type": "boolean"
            },
            "migrationsConfigmap": {
              "description": "Name of the ConfigMap containing migration files, mounted at /flyway/sql; mutually exclusive with migrationPaths",
              "type": [
                "string",
                "null"
              ]
            },
            "migrationPaths": {
              "description": "Comma-separated list of paths to migration files or directories; mutually exclusive with migrationsConfigmap",
              "type": [
                "string",
                "null"
              ]
            },
            "env": {
              "description": "Environment variables specified as direct key/value pairs",
              "type": "object"
            },
            "envFromConfigmaps": {
              "description": "Environment variables sourced from external ConfigMap keys",
              "type": "object"
            },
            "envFromSecrets": {
              "description": "Environment variables sourced from external Secret keys",
              "type": "object"
            },
            "envFromFieldRef": {
              "description": "Environment variables sourced from Pod fields via the downward API",
              "type": "object"
            },
            "resources": {
              "description": "Resource requests and limits for the Flyway init container; defaults to cronjob.resources if not set",
              "properties": {
                "requests": {
                  "properties": {
                    "cpu": {
                      "type": "string"
                    },
                    "memory": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "limits": {
                  "properties": {
                    "cpu": {
                      "type": "string"
                    },
                    "memory": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "resources",
        "schedule"
      ]
    },
    "name": {
      "description": "Service name",
      "type": "string"
    },
    "namespace": {
      "description": "Kubernetes namespace",
      "type": "string"
    },
    "serviceAccount": {
      "description": "ServiceAccount configuration",
      "type": "object",
      "properties": {
        "roleArn": {
          "description": "Optional IAM Role ARN used for eks.amazonaws.com/role-arn annotation",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "externalSecrets": {
      "description": "External Secrets Operator configuration",
      "type": "object",
      "properties": {
        "create": {
          "description": "Enable ExternalSecret creation",
          "type": "boolean",
          "default": false
        },
        "refreshInterval": {
          "description": "Refresh interval for the secret (e.g., '1h', '30m')",
          "type": "string",
          "default": "0"
        },
        "refreshPolicy": {
          "description": "Refresh policy for the secret",
          "type": "string",
          "enum": ["OnChange", "Interval"],
          "default": "OnChange"
        },
        "secretStoreRef": {
          "description": "Reference to SecretStore or ClusterSecretStore",
          "type": "object",
          "properties": {
            "name": {
              "description": "Name of the SecretStore",
              "type": "string"
            },
            "kind": {
              "description": "Kind of the store",
              "type": "string",
              "enum": ["SecretStore", "ClusterSecretStore"],
              "default": "SecretStore"
            }
          },
          "required": ["name"]
        },
        "targetSecret": {
          "description": "Target Kubernetes Secret configuration",
          "type": "object",
          "properties": {
            "name": {
              "description": "Name of the target secret (defaults to microservice name)",
              "type": "string"
            },
            "creationPolicy": {
              "description": "Creation policy for the target secret",
              "type": "string",
              "enum": ["Owner", "Orphan", "Merge", "None"],
              "default": "Merge"
            },
            "deletionPolicy": {
              "description": "Deletion policy for the target secret",
              "type": "string",
              "enum": ["Retain", "Delete"],
              "default": "Retain"
            }
          }
        },
        "data": {
          "description": "List of individual secret keys to sync from external secret manager",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretKey": {
                "description": "Key name in the target Kubernetes Secret",
                "type": "string"
              },
              "remoteRef": {
                "description": "Reference to the remote secret",
                "type": "object",
                "properties": {
                  "key": {
                    "description": "Remote secret key/path",
                    "type": "string"
                  },
                  "property": {
                    "description": "Property to extract from the remote secret",
                    "type": "string"
                  },
                  "version": {
                    "description": "Version identifier for the remote secret",
                    "type": "string"
                  },
                  "conversionStrategy": {
                    "description": "Conversion strategy",
                    "type": "string"
                  },
                  "decodingStrategy": {
                    "description": "Decoding strategy",
                    "type": "string"
                  }
                },
                "required": ["key", "property"],
                "additionalProperties": false
              }
            },
            "required": ["secretKey", "remoteRef"],
            "additionalProperties": false
          },
          "default": []
        },
        "dataFrom": {
          "description": "List of sources to fetch all key/value pairs from. Each entry must contain exactly one of: extract, find, or sourceRef.",
          "type": ["array", "null"],
          "items": {
            "type": "object",
            "oneOf": [
              {
                "description": "Fetch all key/value pairs from a single specific secret",
                "properties": {
                  "extract": {
                    "type": "object",
                    "properties": {
                      "key": {
                        "description": "Remote secret key/path",
                        "type": "string"
                      },
                      "version": {
                        "description": "Version identifier for the remote secret",
                        "type": "string"
                      },
                      "property": {
                        "description": "Property to extract from the remote secret",
                        "type": "string"
                      },
                      "conversionStrategy": {
                        "description": "Conversion strategy for secret keys",
                        "type": "string",
                        "enum": ["Default", "Unicode", "PascalCase", "CamelCase", "UpperCase", "LowerCase"]
                      },
                      "decodingStrategy": {
                        "description": "Decoding strategy for secret values",
                        "type": "string",
                        "enum": ["None", "Base64", "Base64URL", "Auto"]
                      },
                      "metadataPolicy": {
                        "description": "Policy for fetching secret metadata",
                        "type": "string",
                        "enum": ["None", "Fetch"]
                      }
                    },
                    "required": ["key"],
                    "additionalProperties": false
                  },
                  "rewrite": {
                    "$ref": "#/properties/externalSecrets/definitions/rewrite"
                  }
                },
                "required": ["extract"],
                "additionalProperties": false
              },
              {
                "description": "Search for multiple secrets by name (regexp) or tags/metadata",
                "properties": {
                  "find": {
                    "type": "object",
                    "properties": {
                      "path": {
                        "description": "Search path prefix",
                        "type": "string"
                      },
                      "name": {
                        "description": "Filter by secret name using regexp",
                        "type": "object",
                        "properties": {
                          "regexp": {
                            "type": "string"
                          }
                        },
                        "required": ["regexp"],
                        "additionalProperties": false
                      },
                      "tags": {
                        "description": "Filter by tags/metadata",
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "conversionStrategy": {
                        "description": "Conversion strategy for secret keys",
                        "type": "string",
                        "enum": ["Default", "Unicode", "PascalCase", "CamelCase", "UpperCase", "LowerCase"]
                      },
                      "decodingStrategy": {
                        "description": "Decoding strategy for secret values",
                        "type": "string",
                        "enum": ["None", "Base64", "Base64URL", "Auto"]
                      }
                    },
                    "additionalProperties": false
                  },
                  "rewrite": {
                    "$ref": "#/properties/externalSecrets/definitions/rewrite"
                  }
                },
                "required": ["find"],
                "additionalProperties": false
              },
              {
                "description": "Fetch values from a Generator resource",
                "properties": {
                  "sourceRef": {
                    "type": "object",
                    "properties": {
                      "generatorRef": {
                        "type": "object",
                        "properties": {
                          "apiVersion": {
                            "description": "API version of the Generator resource",
                            "type": "string"
                          },
                          "kind": {
                            "description": "Kind of the Generator resource",
                            "type": "string"
                          },
                          "name": {
                            "description": "Name of the Generator resource",
                            "type": "string"
                          }
                        },
                        "required": ["apiVersion", "kind", "name"],
                        "additionalProperties": false
                      }
                    },
                    "required": ["generatorRef"],
                    "additionalProperties": false
                  }
                },
                "required": ["sourceRef"],
                "additionalProperties": false
              }
            ]
          }
        }
      },
      "additionalProperties": true,
      "definitions": {
        "rewrite": {
          "description": "Rewrite rules to transform secret key names",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "regexp": {
                "type": "object",
                "properties": {
                  "source": {
                    "description": "Regexp pattern to match",
                    "type": "string"
                  },
                  "target": {
                    "description": "Replacement string",
                    "type": "string"
                  }
                },
                "required": ["source", "target"],
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "required": [
    "name",
    "namespace"
  ],
  "title": "Values",
  "type": "object"
}
